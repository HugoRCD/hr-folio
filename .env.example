# AI Gateway
AI_GATEWAY_API_KEY=your_value

# Better Auth (min 32 chars)
NUXT_BETTER_AUTH_SECRET=your_value

# GitHub OAuth
NUXT_GITHUB_CLIENT_ID=your_value
NUXT_GITHUB_CLIENT_SECRET=your_value

# GitHub login of the portfolio owner (tools repo). Server checks api.github.com/user with stored OAuth token.
# Optional; defaults to HugoRCD in code for this repo.
# NUXT_FOLIO_OWNER_GITHUB_LOGIN=YourGitHubHandle

# Max /api/chat turns per UTC day for visitors (owners unlimited).
# NUXT_FOLIO_VISITOR_CHAT_DAILY_LIMIT=20

# Intelligence workflows — set as CRON_SECRET in Vercel so cron jobs are authenticated
NUXT_INTELLIGENCE_SECRET=your_value

# Typefully MCP (runIntelligenceTask with source typefully) — API key (Bearer). URL defaults to https://mcp.typefully.com/mcp
# TYPEFULLY_API_KEY=your_value
# Scope: personal account only (ignore Nuxt team sets). Default X handle @hugorcd — or pin the numeric social set id from Typefully:
# TYPEFULLY_SOCIAL_HANDLE=@hugorcd
# TYPEFULLY_SOCIAL_SET_ID=12345
# Optional overrides:
# TYPEFULLY_MCP_URL=https://mcp.typefully.com/mcp
# MCP protocol version if Typefully changes supported versions (default in code: 2025-06-18)
# TYPEFULLY_MCP_PROTOCOL_VERSION=2025-06-18

# Resend (email notifications)
NUXT_PRIVATE_RESEND_API_KEY=your_value
